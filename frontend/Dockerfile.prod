# =============================================================================
# frontend/Dockerfile.prod — Production (multi-stage: build + Next.js standalone)
# =============================================================================

# --- Stage 1: Dependencies ---
FROM public.ecr.aws/docker/library/node:20-slim AS deps

WORKDIR /app

COPY package*.json ./

ENV NPM_CONFIG_INCLUDE_OPTIONAL=true
RUN npm ci --include=optional --no-audit --no-fund --legacy-peer-deps

# --- Stage 2: Build ---
FROM public.ecr.aws/docker/library/node:20-slim AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build-time NEXT_PUBLIC_* variables
ARG NEXT_PUBLIC_NODE_ENV=production
ARG NEXT_PUBLIC_PROJECT_HOST_NAME
ARG NEXT_PUBLIC_ADMIN_PROJECT_HOST_NAME
ARG NEXT_PUBLIC_EMPLOYER_PROJECT_HOST_NAME
ARG NEXT_PUBLIC_PROJECT_SERVER_CLIENT_ID
ARG NEXT_PUBLIC_PROJECT_SERVER_CLIENT_SECRET
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_GOOGLE_CLIENT_SECRET
ARG NEXT_PUBLIC_FACEBOOK_CLIENT_ID
ARG NEXT_PUBLIC_FACEBOOK_CLIENT_SECRET
ARG NEXT_PUBLIC_GOONGAPI_KEY
ARG NEXT_PUBLIC_GOONGAPI_ACCESS_TOKEN
ARG NEXT_PUBLIC_LIVEKIT_URL
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ARG NEXT_PUBLIC_FIREBASE_DATABASE_URL
ARG NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING

ENV NEXT_PUBLIC_NODE_ENV=$NEXT_PUBLIC_NODE_ENV \
    NEXT_PUBLIC_PROJECT_HOST_NAME=$NEXT_PUBLIC_PROJECT_HOST_NAME \
    NEXT_PUBLIC_ADMIN_PROJECT_HOST_NAME=$NEXT_PUBLIC_ADMIN_PROJECT_HOST_NAME \
    NEXT_PUBLIC_EMPLOYER_PROJECT_HOST_NAME=$NEXT_PUBLIC_EMPLOYER_PROJECT_HOST_NAME \
    NEXT_PUBLIC_PROJECT_SERVER_CLIENT_ID=$NEXT_PUBLIC_PROJECT_SERVER_CLIENT_ID \
    NEXT_PUBLIC_PROJECT_SERVER_CLIENT_SECRET=$NEXT_PUBLIC_PROJECT_SERVER_CLIENT_SECRET \
    NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID \
    NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=$NEXT_PUBLIC_GOOGLE_CLIENT_SECRET \
    NEXT_PUBLIC_FACEBOOK_CLIENT_ID=$NEXT_PUBLIC_FACEBOOK_CLIENT_ID \
    NEXT_PUBLIC_FACEBOOK_CLIENT_SECRET=$NEXT_PUBLIC_FACEBOOK_CLIENT_SECRET \
    NEXT_PUBLIC_GOONGAPI_KEY=$NEXT_PUBLIC_GOONGAPI_KEY \
    NEXT_PUBLIC_GOONGAPI_ACCESS_TOKEN=$NEXT_PUBLIC_GOONGAPI_ACCESS_TOKEN \
    NEXT_PUBLIC_LIVEKIT_URL=$NEXT_PUBLIC_LIVEKIT_URL \
    NEXT_PUBLIC_FIREBASE_API_KEY=$NEXT_PUBLIC_FIREBASE_API_KEY \
    NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=$NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN \
    NEXT_PUBLIC_FIREBASE_PROJECT_ID=$NEXT_PUBLIC_FIREBASE_PROJECT_ID \
    NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=$NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET \
    NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=$NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID \
    NEXT_PUBLIC_FIREBASE_APP_ID=$NEXT_PUBLIC_FIREBASE_APP_ID \
    NEXT_PUBLIC_FIREBASE_DATABASE_URL=$NEXT_PUBLIC_FIREBASE_DATABASE_URL \
    NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING=$NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING

ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# --- Stage 3: Run (Next.js standalone server) ---
FROM public.ecr.aws/docker/library/node:20-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy public assets
COPY --from=builder /app/public ./public

# Copy standalone build output
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 80

ENV PORT=80
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
