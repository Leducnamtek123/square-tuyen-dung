{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/pages/**/*.{ts,tsx}",
    "src/middleware.{ts,tsx}",
    "src/instrumentation.{ts,tsx}",
    "src/layouts/index.tsx",
    "src/services/index.ts",
    "src/types/index.ts",
    "src/views/**/index.ts",
    "src/components/Common/DataTableCustom/index.tsx",
    "src/components/Common/DropzoneDialogCustom/index.tsx",
    "src/components/Common/NumberCard/index.tsx",
    "src/components/Common/Controls/MultiSelectCustom/index.tsx",
    "src/components/Common/Controls/MultiSelectSearchCustom/index.tsx",
    "src/components/Features/AIServiceHealthBanner/index.tsx",
    "src/components/Features/AIToolsCard/index.tsx",
    "src/components/Features/AppIntroductionCard/index.tsx",
    "src/components/Features/JobPosts/index.tsx",
    "src/components/Features/VoiceAssistant/components/app/app.tsx",
    "src/components/Features/VoiceAssistant/utils.ts",
    "jest.config.ts",
    "playwright.config.ts",
    "src/test/setup.ts",
    "*.cjs",
    "*.mjs",
    "tools/**/*.{cjs,mjs,ts}",
    "tools-*.mjs"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "*.{ts,tsx,cjs,mjs}",
    "tools/**/*.{ts,tsx,cjs,mjs}"
  ],
  "ignore": [
    "coverage/**",
    "playwright-report/**",
    ".next/**",
    "src/hooks/useFirebaseFireStore.tsx",
    "src/hooks/useFireStoreGetChatRoom.tsx",
    "src/utils/apiClient.ts",
    "src/hooks/AgentsUi/**",
    "src/layouts/components/MuiShell*.tsx",
    "src/components/Features/AiElements/**",
    "src/components/Features/Chats/ChatInfo/**",
    "src/components/Features/VoiceAssistant/hooks/useAgentErrors.tsx",
    "src/components/Features/VoiceAssistant/components/app/theme-provider.tsx",
    "src/components/Features/VoiceAssistant/components/app/theme-toggle.tsx",
    "src/components/Features/VoiceAssistant/components/app/view-controller.tsx",
    "src/components/Features/VoiceAssistant/components/app/welcome-view.tsx",
    "src/components/Features/VoiceAssistant/components/livekit/alert-toast.tsx",
    "src/components/Features/VoiceAssistant/components/livekit/alert.tsx",
    "src/views/adminPages/InterviewsPage/components/InterviewTable.tsx",
    "src/views/adminPages/JobsPage/components/JobFilters.tsx",
    "src/views/adminPages/JobsPage/components/JobTable.tsx",
    "src/views/adminPages/JobNotificationsPage/components/JobNotificationTable.tsx",
    "src/views/adminPages/ProfilesPage/components/ProfileTable.tsx",
    "src/views/adminPages/ResumesPage/components/ResumeTable.tsx",
    "src/views/adminPages/UsersPage/components/ScheduleInterviewDialog.tsx",
    "src/views/employerPages/InterviewPages/components/QuestionGroupTable.tsx",
    "src/views/employerPages/InterviewPages/hooks/useQuestionGroups.ts"
  ]
}
