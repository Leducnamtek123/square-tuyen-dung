# =============================================================================
# .env.example — Template environment variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file to version control
# =============================================================================
COMPOSE_PROJECT_NAME=tuyendung_studio_vn
APP_ENV=development
DEBUG=True
APPEND_SLASH=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
DB_ENGINE=django.db.backends.mysql
DB_HOST=db
DB_NAME=square_db
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_PORT=3306
DB_USER=root

# --- Redis ---
SERVICE_REDIS_HOST=redis
SERVICE_REDIS_PASSWORD=
SERVICE_REDIS_PORT=6379
SERVICE_REDIS_USERNAME=
SERVICE_REDIS_DB=0
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_WORKER_MAX_TASKS_PER_CHILD=20

# --- Elasticsearch ---
ELASTICSEARCH_HOST=elasticsearch:9200

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_PASSWORD=CHANGE_ME_app_password
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_PORT=587

# --- Social Auth ---
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=CHANGE_ME
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=CHANGE_ME

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=square
MINIO_SECURE=False
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_CONSOLE_ADDRESS=:9001

# --- OAuth Client ---
CLIENT_ID=CHANGE_ME_oauth_client_id
CLIENT_SECRET=CHANGE_ME_oauth_client_secret
REQUIRE_CLIENT_SECRET=False
SECRET_KEY=CHANGE_ME_django_secret_key

# --- Web Client URLs ---
WEB_CLIENT_URL=http://localhost:3000
WEB_JOB_SEEKER_CLIENT_URL=http://localhost:3000
WEB_EMPLOYER_CLIENT_URL=http://localhost:3000

# --- Frappe HR Integration ---
FRAPPE_HR_IMAGE=square/frappe-hrms:custom
FRAPPE_HR_FRAPPE_BRANCH=version-16
FRAPPE_HR_IMAGE_PREFIX=frappe
FRAPPE_HR_BUILD_CACHE_BUST=
FRAPPE_HR_SITE_NAME=hrm.tuyendung.square.vn
FRAPPE_HR_PUBLIC_URL=https://hrm.square.vn
NEXT_PUBLIC_FRAPPE_HR_PUBLIC_URL=https://hrm.square.vn
FRAPPE_HR_BASE_URL=http://frappe-hrms-frontend:8080
FRAPPE_HR_API_KEY=
FRAPPE_HR_API_SECRET=
FRAPPE_HR_ADMIN_PASSWORD=CHANGE_ME_frappe_admin_password
FRAPPE_HR_DB_ROOT_PASSWORD=CHANGE_ME_frappe_db_root_password
FRAPPE_HR_DEFAULT_COMPANY=
FRAPPE_HR_DEFAULT_DEPARTMENT=
FRAPPE_HR_DEFAULT_CURRENCY=VND
FRAPPE_HR_DEFAULT_COUNTRY=Vietnam
FRAPPE_HR_DEFAULT_GENDER=Other
FRAPPE_HR_DEFAULT_DATE_OF_BIRTH=1990-01-01
FRAPPE_HR_EMPLOYEE_ROLES=Employee
FRAPPE_HR_RECRUITER_ROLES=HR Manager,HR User
FRAPPE_HR_RECRUITER_READONLY_ROLES=HR User
FRAPPE_HR_SYNC_RECRUITER_ACCOUNTS=true
FRAPPE_HR_TIMEOUT_SECONDS=20
FRAPPE_HR_PORT=8081

# --- LiveKit & AI Services ---
BACKEND_API_URL=http://backend:8000/api
LIVEKIT_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret
AI_LLM_BASE_URL=http://ollama:11434/v1
AI_LLM_MODEL=gemma4:e4b
AI_LLM_API_KEY=
AI_LLM_LOCAL_BASE_URL=http://host.docker.internal:11434/v1
AI_LLM_LOCAL_MODEL=gemma4:e4b
AI_LLM_LOCAL_API_KEY=
AI_LLM_FALLBACK_BASE_URLS=http://host.docker.internal:11434/v1
AI_LLM_FALLBACK_MODELS=gemma4:e4b
AI_LLM_FALLBACK_API_KEYS=
AI_CHAT_MAX_TOOL_ROUNDS=4
AI_STT_BASE_URL=http://whisper:8080/v1
AI_STT_FALLBACK_BASE_URLS=
AI_STT_MODEL=Systran/faster-whisper-large-v3
AI_STT_LANGUAGE=vi
AI_TTS_BASE_URL=http://vieneu-tts:8298/v1
AI_TTS_FALLBACK_BASE_URLS=
AI_TTS_DEFAULT_VOICE=Binh
STT_BASE_URL=http://whisper:8080/v1
TTS_BASE_URL=http://vieneu-tts:8298/v1
TTS_MODE=standard
TTS_BACKBONE_REPO=pnnbao-ump/VieNeu-TTS-0.3B
TTS_DEVICE=auto
VOXBOX_DEVICE=cpu
TTS_CONNECT_TIMEOUT_SECONDS=15
TTS_READ_TIMEOUT_SECONDS=300
TTS_WRITE_TIMEOUT_SECONDS=30
TTS_POOL_TIMEOUT_SECONDS=30
TTS_MAX_RETRIES=3
PREEMPTIVE_GENERATION=1
PREEMPTIVE_GATING=1
MIN_ENDPOINTING_DELAY=0.45
MAX_ENDPOINTING_DELAY=1.5
MIN_CONSECUTIVE_SPEECH_DELAY=0.25
MIN_INTERRUPTION_DURATION=0.75
MIN_INTERRUPTION_WORDS=2

# --- LLM Config ---
LLM_PROVIDER=llama_cpp
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_CTX_SIZE=16384
LLM_MODEL=Qwen2.5-14B-Instruct-Q4_K_M.gguf
OLLAMA_HF_REPO=bartowski/Qwen2.5-14B-Instruct-GGUF
OLLAMA_HF_FILE=Qwen2.5-14B-Instruct-Q4_K_M.gguf
OLLAMA_MODEL=gemma4:e4b
AI_RESUME_LLM_MODEL=gemma4:e4b
AI_RESUME_LLM_TEMPERATURE=0.1
AI_RESUME_LLM_TOP_P=0.9
AI_RESUME_LLM_MAX_TOKENS=420
AI_RESUME_LLM_TIMEOUT_SECONDS=240
AI_RESUME_LLM_CONNECT_TIMEOUT_SECONDS=10
AI_RESUME_OLLAMA_FALLBACK_ENABLED=true
AI_RESUME_PROMPT_MAX_CV_CHARS=2600
AI_RESUME_PROMPT_MAX_JD_CHARS=900
AI_RESUME_PROMPT_MAX_REQUIREMENT_CHARS=700
AI_RESUME_ANALYSIS_MAX_CONCURRENCY=2
AI_RESUME_ANALYSIS_SLOT_WAIT_SECONDS=20
AI_RESUME_ANALYSIS_SLOT_TTL_SECONDS=1800

# --- AI API Keys (optional, for cloud fallback) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# VITE_* — Frontend build variables (baked into JS bundle at build time)
# =============================================================================
VITE_NODE_ENV=development
VITE_PROJECT_HOST_NAME=localhost
VITE_ADMIN_PROJECT_HOST_NAME=admin.localhost
VITE_EMPLOYER_PROJECT_HOST_NAME=employer.localhost
VITE_PROJECT_SERVER_CLIENT_ID=CHANGE_ME
VITE_PROJECT_SERVER_CLIENT_SECRET=CHANGE_ME
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_GOOGLE_CLIENT_ID=CHANGE_ME
VITE_GOOGLE_CLIENT_SECRET=CHANGE_ME

# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=CHANGE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=CHANGE_ME.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=CHANGE_ME
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=CHANGE_ME.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=CHANGE_ME
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING=true
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_JSON_BASE64=
