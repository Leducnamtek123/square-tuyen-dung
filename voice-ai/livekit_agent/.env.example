LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret
BACKEND_API_URL=http://localhost:8000/api
INTERVIEW_AGENT_SHARED_SECRET=CHANGE_ME_same_value_as_api

# STT backend (defaults to Nemotron)
STT_PROVIDER=nemotron
STT_BASE_URL=http://localhost:11435/v1
STT_MODEL=nemotron-speech-streaming
STT_API_KEY=no-key-needed
STT_LANGUAGE=vi

# LLM backend
LLM_BASE_URL=http://localhost:11436/v1
LLM_MODEL=gemma4:e4b
LLM_API_KEY=no-key-needed

# TTS
TTS_VOICE=Ly
PREEMPTIVE_GENERATION=0
PREEMPTIVE_GATING=1
MIN_ENDPOINTING_DELAY=2.0
MAX_ENDPOINTING_DELAY=5.0
MIN_CONSECUTIVE_SPEECH_DELAY=1.0
MIN_INTERRUPTION_DURATION=2.0
MIN_INTERRUPTION_WORDS=5
TTS_CONNECT_TIMEOUT_SECONDS=15
TTS_READ_TIMEOUT_SECONDS=300
TTS_WRITE_TIMEOUT_SECONDS=30
TTS_POOL_TIMEOUT_SECONDS=30
TTS_MAX_RETRIES=3
PREEMPTIVE_GENERATION=0
MIN_ENDPOINTING_DELAY=2.0
MAX_ENDPOINTING_DELAY=5.0
MIN_CONSECUTIVE_SPEECH_DELAY=1.0
PREEMPTIVE_GATING=1
PREEMPTIVE_MIN_WORDS=3
PREEMPTIVE_MIN_CHARS=12
