LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# STT backend (defaults to Nemotron)
STT_PROVIDER=nemotron
STT_BASE_URL=http://localhost:11435/v1
STT_MODEL=nemotron-speech-streaming
STT_API_KEY=no-key-needed
STT_LANGUAGE=vi

# LLM backend
OLLAMA_BASE_URL=http://localhost:11436/v1
OLLAMA_MODEL=qwen3-4b

# TTS
TTS_VOICE=Bình (nam miền Bắc)
PREEMPTIVE_GENERATION=1
MIN_ENDPOINTING_DELAY=0.25
MAX_ENDPOINTING_DELAY=1.0
MIN_CONSECUTIVE_SPEECH_DELAY=0.1
PREEMPTIVE_GATING=1
PREEMPTIVE_MIN_WORDS=3
PREEMPTIVE_MIN_CHARS=12
