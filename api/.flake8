[flake8]
max-line-length = 120
exclude =
    migrations,
    __pycache__,
    manage.py,
    settings.py,
    node_modules,
    .git,
    data,
    logs
ignore =
    # line too long (handled by editor)
    E501,
    # whitespace before ':'
    E203,
    # line break before binary operator
    W503,
    # blank line at end of file
    W391,
    # module level import not at top of file
    E402
per-file-ignores =
    __init__.py:F401,F403
