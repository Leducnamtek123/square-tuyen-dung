# Copy these values into the main app .env after FPT creates the built-in vLLM
# container and gives the HTTP endpoint for port 8000.

LLM_BASE_URL=https://<fpt-port-8000-endpoint>/v1
AI_LLM_BASE_URL=https://<fpt-port-8000-endpoint>/v1
LLM_MODEL=Qwen/Qwen3-14B
AI_LLM_MODEL=Qwen/Qwen3-14B
AI_RESUME_LLM_MODEL=Qwen/Qwen3-14B
LLM_API_KEY=<token-tu-dat>
AI_LLM_API_KEY=<token-tu-dat>
