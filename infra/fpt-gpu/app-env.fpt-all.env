# Copy these values into the main app .env after all 3 FPT GPU containers are
# running and FPT has generated their HTTP endpoints.

LLM_BASE_URL=http://<fpt-llm-port-8000-endpoint>/v1
AI_LLM_BASE_URL=http://<fpt-llm-port-8000-endpoint>/v1
LLM_MODEL=Qwen/Qwen3-14B
AI_LLM_MODEL=Qwen/Qwen3-14B
AI_RESUME_LLM_MODEL=Qwen/Qwen3-14B
AI_LLM_USE_VLLM_PARAMS=1
AI_LLM_ENABLE_THINKING=0
AI_LLM_TEMPERATURE=0.7
AI_LLM_TOP_P=0.8
AI_LLM_TOP_K=20
AI_LLM_MIN_P=0
AI_LLM_PRESENCE_PENALTY=1.5
AI_LLM_REPETITION_PENALTY=1.0
AI_LLM_MAX_TOKENS=2048
LLM_USE_VLLM_PARAMS=1
LLM_ENABLE_THINKING=0
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.8
LLM_TOP_K=20
LLM_MIN_P=0
LLM_PRESENCE_PENALTY=1.5
LLM_REPETITION_PENALTY=1.0
LLM_MAX_COMPLETION_TOKENS=512
LLM_API_KEY=<token-tu-dat>
AI_LLM_API_KEY=<token-tu-dat>

STT_BASE_URL=http://<fpt-whisper-port-8080-endpoint>/v1
AI_STT_BASE_URL=http://<fpt-whisper-port-8080-endpoint>/v1
STT_MODEL=Systran/faster-whisper-large-v3
AI_STT_MODEL=Systran/faster-whisper-large-v3
STT_LANGUAGE=vi
AI_STT_LANGUAGE=vi

TTS_BASE_URL=http://<fpt-tts-port-8298-endpoint>/v1
AI_TTS_BASE_URL=http://<fpt-tts-port-8298-endpoint>/v1
TTS_MODEL=tts-1
AI_TTS_MODEL=tts-1
TTS_VOICE=Ly
AI_TTS_DEFAULT_VOICE=Ly
TTS_DEVICE=cuda
TTS_CODEC_DEVICE=cuda
TTS_MODE=fast
TTS_BACKBONE_REPO=pnnbao-ump/VieNeu-TTS
TTS_GGUF_FILENAME=
TTS_EMOTION=natural
TTS_GPU_MEM_FRACTION=0.30
TTS_INFER_TEMPERATURE=
TTS_INFER_TOP_K=
TTS_MAX_CHARS=
TTS_SPEED=
TTS_DEFAULT_SPEED=
TTS_NORMALIZE_AUDIO=
TTS_PEAK_LIMIT=0.98
TTS_PEAK_NORMALIZE_TARGET=
VOICE_PROFILE_BACKEND_API_URL=https://<your-backend-domain>/api
VOICE_PROFILE_FETCH_TIMEOUT_SECONDS=15
VOICE_PROFILE_AUDIO_TIMEOUT_SECONDS=60
TTS_VOICE_PROFILE_CACHE_DIR=/tmp/vieneu_voice_profiles
