# Copy these values into the main app .env after all 3 FPT GPU containers are
# running and FPT has generated their HTTP endpoints.

LLM_BASE_URL=https://<fpt-llm-port-8000-endpoint>/v1
AI_LLM_BASE_URL=https://<fpt-llm-port-8000-endpoint>/v1
LLM_MODEL=Qwen/Qwen3-14B
AI_LLM_MODEL=Qwen/Qwen3-14B
AI_RESUME_LLM_MODEL=Qwen/Qwen3-14B
LLM_API_KEY=<token-tu-dat>
AI_LLM_API_KEY=<token-tu-dat>

STT_BASE_URL=https://<fpt-whisper-port-8080-endpoint>/v1
AI_STT_BASE_URL=https://<fpt-whisper-port-8080-endpoint>/v1
STT_MODEL=Systran/faster-whisper-large-v3
AI_STT_MODEL=Systran/faster-whisper-large-v3
STT_LANGUAGE=vi
AI_STT_LANGUAGE=vi

TTS_BASE_URL=https://<fpt-tts-port-8298-endpoint>/v1
AI_TTS_BASE_URL=https://<fpt-tts-port-8298-endpoint>/v1
TTS_MODEL=tts-1
AI_TTS_MODEL=tts-1
TTS_VOICE=Bình (nam miền Bắc)
AI_TTS_DEFAULT_VOICE=Bình (nam miền Bắc)
